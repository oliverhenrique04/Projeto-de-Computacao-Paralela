# ────────────────────────────────────────────────────────────────────
# CONNECTONGS — Configuração do Benchmark Distribuído
#
# Edite este arquivo para personalizar os testes.
# Após editar, rode: docker compose up --build
# ────────────────────────────────────────────────────────────────────

# Número TOTAL de requisições distribuídas entre os 4 workers
# Mínimo: 4  |  Máximo: 1000  (limitado pelos usuários do banco)
# Cada worker recebe TOTAL_REQUESTS / 4 requisições
TOTAL_REQUESTS=100

# Modo dos workers seriais (worker_1 e worker_2)
MODE_SERIAL=serial

# Modo dos workers concorrentes (worker_3 e worker_4)
MODE_CONCURRENT=concurrent

# Threads simultâneas por worker concorrente
CONCURRENT_N_W3=5
CONCURRENT_N_W4=10
